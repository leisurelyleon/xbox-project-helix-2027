<Window
    x:Class="HelixShell.Views.BootSequence"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Project Helix Boot">

    <Grid Background="#020617">
        <Grid.Resources>
            <Storyboard x:Name="BootAnimation" AutoReverse="False">
                <DoubleAnimation Storyboard.TargetName="LogoGlow" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:2">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseInOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="WelcomeText" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:3" BeginTime="0:0:1"/>
            </Storyboard>
        </Grid.Resources>

        <Ellipse x:Name="LogoGlow" Width="800" Height="800" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#40D946EF" Offset="0"/> <GradientStop Color="#20F97316" Offset="0.5"/> <GradientStop Color="#00020617" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
            <Image Source="ms-appx:///Assets/HelixLogo_White.png" Width="120" Height="120" RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                </Image.RenderTransform>
            </Image>
            
            <TextBlock x:Name="WelcomeText" Text="Initializing Windows 12 Core..." 
                       Foreground="#94A3B8" FontFamily="Segoe UI Variable Display" 
                       FontSize="16" CharacterSpacing="200" Opacity="0"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
