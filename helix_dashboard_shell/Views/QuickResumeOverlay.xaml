<UserControl
    x:Class="HelixShell.Views.QuickResumeOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#B3000000"> <Border Width="400" HorizontalAlignment="Right" Background="#0F172A" CornerRadius="24,0,0,24" 
                BorderBrush="#33FFFFFF" BorderThickness="1,0,0,0" Padding="32">
            <StackPanel Spacing="24">
                <TextBlock Text="Quick Resume Hub" Foreground="White" FontSize="24" FontWeight="Bold"/>
                
                <ListView ItemsSource="{x:Bind ViewModel.SuspendedStates}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="80" Margin="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Image Source="{Binding Icon}" Width="60" Height="60" CornerRadius="8"/>
                                
                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding GameTitle}" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding EnvironmentType}" Foreground="#F97316" FontSize="12"/>
                                    <ProgressBar Value="{Binding ResumeProgress}" Margin="0,8,0,0" 
                                                 Visibility="{Binding IsResuming, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
