<Page
    x:Class="HelixShell.Views.UnifiedStorefront"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HelixShell.Views"
    Background="Transparent">

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <AcrylicBrush TintColor="#0F172A" TintOpacity="0.8" FallbackColor="#0F172A"/>
            </Rectangle.Fill>
        </Rectangle>

        <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <StackPanel Padding="48,64,48,0" Spacing="32">
                <TextBlock Text="THE UNIFIED MARKETPLACE" FontFamily="Segoe UI Variable Display" 
                           FontWeight="SemiLight" FontSize="32" Foreground="White" CharacterSpacing="100"/>

                <GridView ItemsSource="{x:Bind ViewModel.FeaturedGames}" SelectionMode="None">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="320" Height="450" Margin="0,0,24,24" CornerRadius="12" Background="#1E293B">
                                <Image Source="{Binding CoverArtUrl}" Stretch="UniformToFill"/>
                                
                                <Border VerticalAlignment="Bottom" Height="100" CornerRadius="0,0,12,12">
                                    <Border.Background>
                                        <AcrylicBrush TintColor="Black" TintOpacity="0.6"/>
                                    </Border.Background>
                                    <StackPanel Padding="16">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="White" FontSize="18"/>
                                        <TextBlock Text="{Binding PlatformTag}" Foreground="#A855F7" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
